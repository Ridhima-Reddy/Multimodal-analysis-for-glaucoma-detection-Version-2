# Resumability helper functions
def get_progress_file():
    """Return the path to the progress JSON file."""
    return "cv_progress.json"

def load_progress():
    """Load completed folds from progress file."""
    progress_file = get_progress_file()
    if os.path.exists(progress_file):
        with open(progress_file, 'r') as f:
            return json.load(f)
    return {"completed_folds": []}

def save_progress(completed_folds):
    """Save completed folds to progress file."""
    progress_file = get_progress_file()
    with open(progress_file, 'w') as f:
        json.dump({"completed_folds": completed_folds}, f, indent=2)

