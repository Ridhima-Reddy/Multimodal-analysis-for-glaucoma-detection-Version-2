def set_seed(seed=42):
    random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)

def compute_metrics(y_true, y_probs, threshold=0.5):
    y_true = torch.tensor(y_true).numpy()
    y_probs = torch.tensor(y_probs).numpy()
    auc = roc_auc_score(y_true, y_probs)
    y_pred = (y_probs >= threshold).astype(int)
    acc = accuracy_score(y_true, y_pred)
    tn, fp, fn, tp = confusion_matrix(y_true, y_pred).ravel()
    sens = tp / (tp + fn)
    spec = tn / (tn + fp)
    return auc, acc, sens, spec

def clean_dataset_directory(data_dir):
    """Create a clean dataset directory without hidden folders"""
    clean_root = tempfile.mkdtemp(prefix="clean_fundus_")
    
    # Get valid class directories (exclude hidden folders like .ipynb_checkpoints)
    valid_classes = [d for d in os.listdir(data_dir) 
                     if os.path.isdir(os.path.join(data_dir, d)) 
                     and not d.startswith('.')]
    
    print(f"📁 Found valid classes: {valid_classes}")
    
    for cls in valid_classes:
        src_dir = os.path.join(data_dir, cls)
        dst_dir = os.path.join(clean_root, cls)
        os.makedirs(dst_dir, exist_ok=True)
        
        # Copy only image files, exclude hidden files
        image_files = [f for f in os.listdir(src_dir) 
                      if f.lower().endswith(('.png', '.jpg', '.jpeg', '.tif', '.tiff', '.bmp'))
                      and not f.startswith('.')]
        
        print(f"📸 Copying {len(image_files)} images from {cls}...")
        for img_file in image_files:
            src_path = os.path.join(src_dir, img_file)
            dst_path = os.path.join(dst_dir, img_file)
            shutil.copy2(src_path, dst_path)
    
    return clean_root, valid_classes

class SimpleFundusDataset(Dataset):
    """Simple dataset that directly resizes images without ROI detection"""
    def __init__(self, root_dir, transform=None):
        self.root_dir = root_dir
        self.transform = transform
        
        # Load the original dataset structure
        self.original_dataset = ImageFolder(root_dir)
        self.classes = self.original_dataset.classes
        self.class_to_idx = self.original_dataset.class_to_idx
        self.samples = self.original_dataset.samples
        
    def __len__(self):
        return len(self.samples)
    
    def __getitem__(self, idx):
        img_path, label = self.samples[idx]
        
        # Load image using PIL for compatibility with torchvision transforms
        from PIL import Image
        image = Image.open(img_path).convert('RGB')
        
        if self.transform:
            image = self.transform(image)
            
        return image, label

def train_model_for_fold(model, train_loader, val_loader, fold, pos_weight, epochs=30, lr=1e-4):
    """Train model for a specific fold with class weighting"""
    # Use the provided pos_weight (tensor on correct device)
    criterion = nn.BCEWithLogitsLoss(pos_weight=pos_weight)
    
    # Two-stage optimizer strategy
    optimizer_stage1 = torch.optim.AdamW([
        {'params': model.features.parameters(), 'lr': lr/10},  # Lower LR for features
        {'params': model.classifier.parameters(), 'lr': lr}     # Higher LR for classifier
    ], weight_decay=1e-4)
    
    optimizer_stage2 = torch.optim.AdamW(model.parameters(), lr=lr/10, weight_decay=1e-4)
    
    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(optimizer_stage1, mode='max', factor=0.5, patience=3)
    
    best_auc = 0.0
    best_metrics = {}
    fold_model_path = f"best_efficientnet_fold_{fold}.pth"

    # ---------------- Two-Stage Training Loop ----------------
    print(f"\n🚀 Starting Stage 1: Feature Extraction (frozen backbone) for Fold {fold}...")
    
    # Stage 1: Freeze backbone, train only classifier
    for param in model.features.parameters():
        param.requires_grad = False
    
    for epoch in range(1, epochs//2 + 1):
        model.train()
        total_loss = 0
        
        for imgs, labels in tqdm(train_loader, desc=f"Fold {fold} Stage1 Epoch {epoch}/{epochs//2}"):
            imgs, labels = imgs.to(device), labels.float().to(device)
            optimizer_stage1.zero_grad()
            out = model(imgs).squeeze(1)
            loss = criterion(out, labels)
            loss.backward()
            optimizer_stage1.step()
            total_loss += loss.item() * imgs.size(0)
        
        avg_loss = total_loss / len(train_loader.dataset)

        # Validation
        model.eval()
        all_probs, all_labels = [], []
        with torch.no_grad():
            for imgs, labels in val_loader:
                imgs = imgs.to(device)
                out = torch.sigmoid(model(imgs).squeeze(1)).cpu()
                all_probs.extend(out)
                all_labels.extend(labels)
        
        auc, acc, sens, spec = compute_metrics(all_labels, all_probs)
        scheduler.step(auc)
        
        print(f"Fold {fold} Stage1 Epoch {epoch} | Loss {avg_loss:.4f} | Val AUC {auc:.4f} | Acc {acc:.3f} | Sens {sens:.3f} | Spec {spec:.3f}")
        print(f"Learning Rate: {optimizer_stage1.param_groups[0]['lr']:.2e}")

        if auc > best_auc:
            best_auc = auc
            best_metrics = {'auc': auc, 'acc': acc, 'sens': sens, 'spec': spec}
            torch.save(model.state_dict(), fold_model_path)
            print(f"✅ Saved best model for fold {fold}")

    print(f"\n🔥 Starting Stage 2: Fine-tuning (unfrozen backbone) for Fold {fold}...")
    
    # Stage 2: Unfreeze all layers for fine-tuning
    for param in model.parameters():
        param.requires_grad = True
    
    # Use lower learning rate for fine-tuning
    for g in optimizer_stage2.param_groups:
        g['lr'] = lr / 10

    for epoch in range(epochs//2 + 1, epochs + 1):
        model.train()
        total_loss = 0
        
        for imgs, labels in tqdm(train_loader, desc=f"Fold {fold} Stage2 Epoch {epoch}/{epochs}"):
            imgs, labels = imgs.to(device), labels.float().to(device)
            optimizer_stage2.zero_grad()
            out = model(imgs).squeeze(1)
            loss = criterion(out, labels)
            loss.backward()
            optimizer_stage2.step()
            total_loss += loss.item() * imgs.size(0)
        
        avg_loss = total_loss / len(train_loader.dataset)

        # Validation
        model.eval()
        all_probs, all_labels = [], []
        with torch.no_grad():
            for imgs, labels in val_loader:
                imgs = imgs.to(device)
                out = torch.sigmoid(model(imgs).squeeze(1)).cpu()
                all_probs.extend(out)
                all_labels.extend(labels)
        
        auc, acc, sens, spec = compute_metrics(all_labels, all_probs)
        
        print(f"Fold {fold} Stage2 Epoch {epoch} | Loss {avg_loss:.4f} | Val AUC {auc:.4f} | Acc {acc:.3f} | Sens {sens:.3f} | Spec {spec:.3f}")
        print(f"Learning Rate: {optimizer_stage2.param_groups[0]['lr']:.2e}")

        if auc > best_auc:
            best_auc = auc
            best_metrics = {'auc': auc, 'acc': acc, 'sens': sens, 'spec': spec}
            torch.save(model.state_dict(), fold_model_path)
            print(f"✅ Saved best model for fold {fold}")

    return best_metrics, fold_model_path

