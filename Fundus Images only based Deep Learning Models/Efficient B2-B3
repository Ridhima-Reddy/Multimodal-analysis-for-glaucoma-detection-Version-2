def main(data_dir="Dataset",
         img_size=224, batch_size=32, epochs=30, lr=1e-4,
         val_split=0.15, n_splits=5):
    
    print("Device:", device)
    set_seed(42)

    # ---------------- Inspect folder structure ----------------
    print(f"\n📁 Looking inside data directory: {data_dir}")
    if not os.path.exists(data_dir):
        raise FileNotFoundError(f"❌ Data directory not found: {data_dir}")

    print("Subfolders found:")
    for item in os.listdir(data_dir):
        path = os.path.join(data_dir, item)
        if os.path.isdir(path):
            # Count only image files, exclude hidden files
            image_files = [f for f in os.listdir(path) 
                          if f.lower().endswith(('.png', '.jpg', '.jpeg', '.tif', '.tiff', '.bmp'))
                          and not f.startswith('.')]
            print(f" - {item}/  ({len(image_files)} image files)")
        else:
            print(f" - {item} (file)")

    print("\n🔍 Checking for image samples in each folder:")
    for cls in os.listdir(data_dir):
        cls_path = os.path.join(data_dir, cls)
        if not os.path.isdir(cls_path) or cls.startswith('.'):
            continue
        imgs = [f for f in os.listdir(cls_path) 
                if f.lower().endswith(('.png', '.jpg', '.jpeg', '.tif', '.tiff', '.bmp'))
                and not f.startswith('.')]
        print(f"Class: {cls} | Found {len(imgs)} images")
        if imgs:
            print("  e.g. →", imgs[:3])

    # ---------------- Clean dataset directory ----------------
    print("\n🧹 Creating clean dataset directory...")
    clean_data_dir, valid_classes = clean_dataset_directory(data_dir)
    print(f"✅ Clean dataset created at: {clean_data_dir}")
    print(f"📊 Valid classes for training: {valid_classes}")

    if len(valid_classes) < 2:
        raise RuntimeError(f"❌ Expected ≥2 class folders but found: {valid_classes}")

    # ---------------- Enhanced Data Transforms ----------------
    train_t = T.Compose([
        T.Resize((img_size, img_size)),
        T.RandomHorizontalFlip(p=0.5),
        T.RandomVerticalFlip(p=0.2),
        T.RandomRotation(degrees=15),
        T.ColorJitter(brightness=0.2, contrast=0.2, saturation=0.1, hue=0.02),
        T.RandomAffine(degrees=0, translate=(0.1, 0.1), scale=(0.9, 1.1)),
        T.ToTensor(),
        T.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]),
    ])
    
    val_t = T.Compose([
        T.Resize((img_size, img_size)),
        T.ToTensor(),
        T.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]),
    ])

    # ---------------- Load dataset with direct resizing ----------------
    print("\n🖼️ Loading dataset with direct resizing...")
    full_dataset = SimpleFundusDataset(root_dir=clean_data_dir, transform=train_t)
    print(f"✅ Dataset loaded successfully with {len(full_dataset)} total images")
    print(f"Classes detected: {full_dataset.classes}")

    # ---------------- 5-Fold Cross Validation with Resume ----------------
    print(f"\n🎯 Starting {n_splits}-Fold Cross Validation (resumable)...")
    
    # Load progress
    progress = load_progress()
    completed_folds = progress["completed_folds"]
    print(f"📂 Previously completed folds: {completed_folds}")
    
    # Create KFold splitter
    kfold = KFold(n_splits=n_splits, shuffle=True, random_state=42)
    
    # Store results for each fold (combine completed and new ones)
    all_fold_results = []  # will be list of dicts
    
    # We need to process all folds to get indices, but skip training if already completed.
    # We'll store the splits in a list to avoid recomputing.
    fold_splits = list(kfold.split(full_dataset))
    
    for fold_idx, (train_idx, test_idx) in enumerate(fold_splits):
        fold_num = fold_idx + 1
        
        # Check if this fold is already completed and model file exists
        fold_model_path = f"best_efficientnet_fold_{fold_num}.pth"
        fold_done = (fold_num in completed_folds) and os.path.exists(fold_model_path)
        
        if fold_done:
            print(f"\n⏩ Skipping Fold {fold_num} (already completed)")
            # Load the result from progress file (we stored it in completed_folds)
            # We need to get the metrics from progress; we stored full metrics.
            # To keep it simple, we can store the metrics in the progress as well.
            # Let's store a list of result dicts in progress.
            # I'll modify to store full results.
            # For now, we'll just read the result from the progress file.
            # But we need the metrics to compute final averages.
            # Let's reload the progress and get the result for this fold.
            progress = load_progress()
            # Find the result for this fold
            fold_result = None
            for r in progress.get("fold_results", []):
                if r["fold"] == fold_num:
                    fold_result = r
                    break
            if fold_result is not None:
                all_fold_results.append(fold_result)
                print(f"   Loaded results: AUC={fold_result['test_auc']:.4f}, Acc={fold_result['test_acc']:.3f}")
            else:
                # Fallback: compute from saved model? better to skip.
                print("⚠️  Progress incomplete for this fold; will recompute.")
                fold_done = False  # force recompute
        else:
            print(f"\n{'='*60}")
            print(f"🔄 Processing Fold {fold_num}/{n_splits}")
            print(f"{'='*60}")
            
            # Split train_idx further into train and validation
            n_train = len(train_idx)
            n_val = int(val_split * n_train)
            n_train_final = n_train - n_val
            
            # Shuffle train indices for val split
            np.random.shuffle(train_idx)
            train_indices = train_idx[:n_train_final]
            val_indices = train_idx[n_train_final:]
            
            # --------------------------------------------------------------
            # COMPUTE PER‑FOLD CLASS WEIGHT from training set only
            # --------------------------------------------------------------
            train_labels = [full_dataset.original_dataset.samples[i][1] for i in train_indices]
            pos_count = sum(train_labels)               # Glaucoma (class 1)
            neg_count = len(train_labels) - pos_count   # Normal (class 0)
            pos_weight = torch.tensor([neg_count / pos_count]).to(device)
            print(f"📊 Fold {fold_num} class distribution (training):")
            print(f"   Normal (0): {neg_count}, Glaucoma (1): {pos_count}")
            print(f"   pos_weight = {pos_weight.item():.3f}")
            
            # Create subsets for this fold
            train_subset = Subset(full_dataset, train_indices)
            val_subset = Subset(full_dataset, val_indices)
            test_subset = Subset(full_dataset, test_idx)
            
            # Apply val transform to validation and test sets
            val_subset.dataset.transform = val_t
            test_subset.dataset.transform = val_t
            
            # Create data loaders
            train_loader = DataLoader(train_subset, batch_size=batch_size, shuffle=True, num_workers=4, pin_memory=True)
            val_loader = DataLoader(val_subset, batch_size=batch_size, shuffle=False, num_workers=4, pin_memory=True)
            test_loader = DataLoader(test_subset, batch_size=batch_size, shuffle=False, num_workers=4, pin_memory=True)
            
            print(f"📊 Fold {fold_num} Dataset Sizes:")
            print(f"   Training: {len(train_subset)} images")
            print(f"   Validation: {len(val_subset)} images")
            print(f"   Testing: {len(test_subset)} images")
            
            # ---------------- Initialize Model for this fold ----------------
            model = models.efficientnet_b2(pretrained=True)
            model.classifier = nn.Sequential(
                nn.Dropout(p=0.3, inplace=True),
                nn.Linear(model.classifier[1].in_features, 1)
            )
            model = model.to(device)
            
            # Train model for this fold (pass pos_weight)
            best_val_metrics, model_path = train_model_for_fold(
                model, train_loader, val_loader, fold_num, pos_weight, epochs, lr
            )
            
            # ---------------- Test Evaluation for this fold ----------------
            print(f"\n📊 Evaluating Fold {fold_num} on test set...")
            model.load_state_dict(torch.load(model_path))
            model.eval()
            all_probs, all_labels = [], []
            with torch.no_grad():
                for imgs, labels in test_loader:
                    imgs = imgs.to(device)
                    out = torch.sigmoid(model(imgs).squeeze(1)).cpu()
                    all_probs.extend(out)
                    all_labels.extend(labels)
            
            test_auc, test_acc, test_sens, test_spec = compute_metrics(all_labels, all_probs)
            
            fold_result = {
                'fold': fold_num,
                'test_auc': float(test_auc),
                'test_acc': float(test_acc),
                'test_sens': float(test_sens),
                'test_spec': float(test_spec),
                'best_val_auc': best_val_metrics['auc']
            }
            all_fold_results.append(fold_result)
            
            # Save progress: update completed_folds and store the result
            if fold_num not in completed_folds:
                completed_folds.append(fold_num)
            # Also store fold_result in progress under "fold_results"
            progress = load_progress()  # re-load to avoid race
            if "fold_results" not in progress:
                progress["fold_results"] = []
            # Remove old entry if any, then append
            progress["fold_results"] = [r for r in progress.get("fold_results", []) if r["fold"] != fold_num]
            progress["fold_results"].append(fold_result)
            progress["completed_folds"] = completed_folds
            save_progress(completed_folds)  # save only completed_folds list (we'll separately save the results)
            # Actually we should save both, but to avoid duplication we'll save the whole progress with fold_results.
            # We'll update the function to save the entire dict.
            # Let's adjust save_progress to save the full dict.
            # I'll redefine save_progress to accept full progress dict.
            def save_full_progress(progress_dict):
                with open(get_progress_file(), 'w') as f:
                    json.dump(progress_dict, f, indent=2)
            save_full_progress(progress)  # save updated progress
    
    # After all folds, compute final metrics from all_fold_results
    if not all_fold_results:
        print("⚠️  No folds completed. Check your data and progress.")
        return
    
    # ---------------- Final Cross-Validation Results ----------------
    print(f"\n{'='*80}")
    print("🎯 5-FOLD CROSS VALIDATION FINAL RESULTS")
    print(f"{'='*80}")
    
    # Extract test metrics
    test_metrics = np.array([[r['test_auc'], r['test_acc'], r['test_sens'], r['test_spec']] for r in all_fold_results])
    mean_metrics = test_metrics.mean(axis=0)
    std_metrics = test_metrics.std(axis=0)
    
    print(f"\n📊 Average Performance across {len(all_fold_results)} folds:")
    print(f"🏆 AUC:          {mean_metrics[0]:.4f} ± {std_metrics[0]:.4f}")
    print(f"🎯 Accuracy:     {mean_metrics[1]:.3f} ± {std_metrics[1]:.3f}")
    print(f"❤️  Sensitivity:  {mean_metrics[2]:.3f} ± {std_metrics[2]:.3f}")
    print(f"🛡️  Specificity:  {mean_metrics[3]:.3f} ± {std_metrics[3]:.3f}")
    
    print(f"\n📈 Detailed Fold Results:")
    for r in all_fold_results:
        print(f"Fold {r['fold']}: AUC={r['test_auc']:.4f}, Acc={r['test_acc']:.3f}, Sens={r['test_sens']:.3f}, Spec={r['test_spec']:.3f}")
    
    # Cleanup temporary directories
    try:
        shutil.rmtree(clean_data_dir)
    except:
        pass

