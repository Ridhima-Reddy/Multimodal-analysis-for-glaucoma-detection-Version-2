# --- Single-Split ResNet-18 Baseline Training Pipeline for Multimodal Fusion ---
import os
import random
import shutil
import tempfile
import json
from pathlib import Path
from tqdm import tqdm

import torch
import torch.nn as nn
from torch.utils.data import DataLoader, Subset
import torchvision.transforms as T
import torchvision.models as models
from torchvision.datasets import ImageFolder

from sklearn.model_selection import StratifiedShuffleSplit
from sklearn.metrics import roc_auc_score, accuracy_score, confusion_matrix
import numpy as np

# -------------------------
def set_seed(seed=42):
    random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)

def compute_metrics(y_true, y_probs, threshold=0.5):
    y_true = torch.tensor(y_true).numpy()
    y_probs = torch.tensor(y_probs).numpy()
    auc = roc_auc_score(y_true, y_probs)
    y_pred = (y_probs >= threshold).astype(int)
    acc = accuracy_score(y_true, y_pred)
    tn, fp, fn, tp = confusion_matrix(y_true, y_pred).ravel()
    sens = tp / (tp + fn) if (tp + fn) > 0 else 0
    spec = tn / (tn + fp) if (tn + fp) > 0 else 0
    return auc, acc, sens, spec

# -------------------------
# State Resumability Manifest Configuration
# -------------------------
PROGRESS_FILE = "training_progress_resnet18.json"
CHECKPOINT_PATH = "checkpoint_resnet18.pth"
BEST_MODEL_PATH = "best_enhanced_resnet18.pth"

def load_progress():
    if os.path.exists(PROGRESS_FILE):
        with open(PROGRESS_FILE, 'r') as f:
            return json.load(f)
    return {"start_epoch": 1, "best_auc": 0.0, "patience_counter": 0, "completed": False}

def save_progress(epoch, best_auc, patience_counter, completed=False):
    with open(PROGRESS_FILE, 'w') as f:
        json.dump({
            "start_epoch": epoch + 1,
            "best_auc": float(best_auc),
            "patience_counter": patience_counter,
            "completed": completed
        }, f, indent=2)

# -------------------------
def main(data_dir="Dataset", img_size=224, batch_size=32, epochs=50, lr=1e-4):
    device = "cuda" if torch.cuda.is_available() else "cpu"
    print("Using device:", device)
    set_seed(42)

    # Inspect data directory
    print(f"\n📁 Looking inside data directory: {data_dir}")
    if not os.path.exists(data_dir):
        raise FileNotFoundError(f"❌ Data directory not found: {data_dir}")

    valid_class_dirs = [d for d in os.listdir(data_dir)
                        if os.path.isdir(os.path.join(data_dir, d)) and not d.startswith('.')]

    clean_root = tempfile.mkdtemp(prefix="fundus_clean_")
    for cls in valid_class_dirs:
        shutil.copytree(os.path.join(data_dir, cls), os.path.join(clean_root, cls))
    print(f"✅ Using cleaned dataset at: {clean_root}")

    # Data Transforms
    train_t = T.Compose([
        T.Resize((img_size, img_size)),
        T.RandomHorizontalFlip(p=0.5),
        T.RandomRotation(15),
        T.RandomAffine(0, translate=(0.1, 0.1), scale=(0.9, 1.1)),
        T.ColorJitter(brightness=0.2, contrast=0.2, saturation=0.1, hue=0.02),
        T.ToTensor(),
        T.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]),
    ])
    val_t = T.Compose([
        T.Resize((img_size, img_size)),
        T.ToTensor(),
        T.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]),
    ])

    full_dataset = ImageFolder(root=clean_root, transform=train_t)
    print(f"✅ Loaded dataset with {len(full_dataset)} total images")

    # Generate a reproducible 80/20 split based on class stratification
    labels = [sample[1] for sample in full_dataset.samples]
    sss = StratifiedShuffleSplit(n_splits=1, test_size=0.2, random_state=42)
    train_idx, val_idx = next(sss.split(np.zeros(len(labels)), labels))

    train_subset = Subset(full_dataset, train_idx)
    val_subset = Subset(full_dataset, val_idx)
    val_subset.dataset.transform = val_t  # Assign validation transform

    # Calculate training set class weights
    train_labels = [labels[i] for i in train_idx]
    pos_count = sum(train_labels)
    neg_count = len(train_labels) - pos_count
    pos_weight = torch.tensor([neg_count / pos_count]).to(device)
    print(f"📊 Training distribution: Normal={neg_count}, Glaucoma={pos_count} -> pos_weight={pos_weight.item():.3f}")

    train_loader = DataLoader(train_subset, batch_size=batch_size, shuffle=True, num_workers=4, pin_memory=True)
    val_loader = DataLoader(val_subset, batch_size=batch_size, shuffle=False, num_workers=4, pin_memory=True)

    # Initialize Architecture
    model = models.resnet18(pretrained=True)
    model.fc = nn.Sequential(
        nn.Dropout(0.2),
        nn.Linear(model.fc.in_features, 1)
    )
    model = model.to(device)

    criterion = nn.BCEWithLogitsLoss(pos_weight=pos_weight)
    optimizer = torch.optim.AdamW(model.parameters(), lr=lr, weight_decay=1e-4)
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=epochs)

    # Load Epoch-Level Progress state if it exists
    progress = load_progress()
    if progress["completed"]:
        print(f"\n⏩ Training already completed according to '{PROGRESS_FILE}'. Exiting.")
        shutil.rmtree(clean_root)
        return

    start_epoch = progress["start_epoch"]
    best_auc = progress["best_auc"]
    patience_counter = progress["patience_counter"]
    patience = 10 

    if start_epoch > 1 and os.path.exists(CHECKPOINT_PATH):
        print(f"🔄 Resuming execution from Checkpoint Epoch {start_epoch}...")
        checkpoint = torch.load(CHECKPOINT_PATH, map_location=device)
        model.load_state_dict(checkpoint['model_state_dict'])
        optimizer.load_state_dict(checkpoint['optimizer_state_dict'])
        scheduler.load_state_dict(checkpoint['scheduler_state_dict'])

    print(f"\n🎯 Starting Training Loop from Epoch {start_epoch} to {epochs}...")
    
    for epoch in range(start_epoch, epochs + 1):
        model.train()
        total_loss = 0

        for imgs, batch_labels in tqdm(train_loader, desc=f"Epoch {epoch}/{epochs}"):
            imgs, batch_labels = imgs.to(device), batch_labels.float().to(device)
            optimizer.zero_grad()

            out = model(imgs).squeeze(1)
            loss = criterion(out, batch_labels)
            loss.backward()
            nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
            optimizer.step()

            total_loss += loss.item() * imgs.size(0)

        scheduler.step()

        # Validation Step
        model.eval()
        all_probs, all_labels = [], []
        with torch.no_grad():
            for imgs, batch_labels in val_loader:
                imgs = imgs.to(device)
                out = torch.sigmoid(model(imgs).squeeze(1)).cpu()
                all_probs.extend(out)
                all_labels.extend(batch_labels)

        auc, acc, sens, spec = compute_metrics(all_labels, all_probs)
        print(f"✨ Val Evaluation → AUC: {auc:.4f} | Acc: {acc:.3f} | Sens: {sens:.3f} | Spec: {spec:.3f}")

        # Check performance improvement
        if auc > best_auc:
            best_auc = auc
            patience_counter = 0
            torch.save(model.state_dict(), BEST_MODEL_PATH)
            print(f"✅ Saved new optimal model weights to '{BEST_MODEL_PATH}'")
        else:
            patience_counter += 1

        # Save standard checkpoint state for crash resiliency
        torch.save({
            'model_state_dict': model.state_dict(),
            'optimizer_state_dict': optimizer.state_dict(),
            'scheduler_state_dict': scheduler.state_dict(),
        }, CHECKPOINT_PATH)
        
        save_progress(epoch, best_auc, patience_counter, completed=False)

        if patience_counter >= patience:
            print(f"🛑 Early stopping triggered at epoch {epoch}. Model performance stabilized.")
            break

    # Mark training complete
    save_progress(epochs, best_auc, patience_counter, completed=True)
    if os.path.exists(CHECKPOINT_PATH):
        os.remove(CHECKPOINT_PATH)  # Clean intermediate checkpoint file on graceful exit

    print("\n==========================================")
    print(f"🏆 Baseline ResNet-18 Model Training Complete!")
    print(f"Optimal Validation Target ROC-AUC achieved: {best_auc:.4f}")
    print(f"Weights preserved for Stage 2 Fusion: '{BEST_MODEL_PATH}'")
    print("==========================================")

    shutil.rmtree(clean_root)
    print("🧹 Cleaned temporary staging directory.")

if __name__ == "__main__":
    main()
